{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://formal-check.dev/schema/formal.schema.json",
  "title": "formal-check contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "project",
    "maturity",
    "toolchains",
    "specs",
    "invariants",
    "actions",
    "proof_obligations",
    "policy"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "project": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "domain": {"type": "string"},
        "owners": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "maturity": {
      "type": "string",
      "enum": ["discovering", "advisory", "enforced"]
    },
    "toolchains": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "pinset": {"type": "string"},
        "allow_auto_sync": {"type": "boolean"}
      }
    },
    "specs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "kind", "entry"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "kind": {"type": "string", "enum": ["tla", "z3py"]},
          "entry": {"type": "string", "minLength": 1},
          "module": {"type": "string"},
          "cfg": {"type": "string"},
          "checker": {"type": "string", "enum": ["apalache", "tlc"]},
          "profiles": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "checker": {"type": "string", "enum": ["apalache", "tlc"]},
                "length": {"type": "integer", "minimum": 0},
                "workers": {"type": "integer", "minimum": 1}
              }
            }
          },
          "objective": {"type": "string"}
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "kind": {"const": "tla"}
              }
            },
            "then": {
              "required": ["module"]
            }
          }
        ]
      }
    },
    "invariants": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "spec", "expr", "kind", "severity", "maps_to"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "spec": {"type": "string", "minLength": 1},
          "expr": {"type": "string", "minLength": 1},
          "kind": {"type": "string", "enum": ["safety", "liveness", "type", "inductive"]},
          "severity": {"type": "string", "enum": ["critical", "high", "medium", "low"]},
          "maps_to": {
            "type": "object",
            "additionalProperties": false,
            "required": ["code", "tests"],
            "properties": {
              "code": {
                "type": "array",
                "items": {"type": "string"}
              },
              "tests": {
                "type": "array",
                "items": {"type": "string"}
              }
            }
          }
        }
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "spec", "tla_action", "implemented_by"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "spec": {"type": "string", "minLength": 1},
          "tla_action": {"type": "string", "minLength": 1},
          "implemented_by": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },
    "proof_obligations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "backend", "entry", "objective"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "spec": {"type": "string"},
          "source_spec": {"type": "string"},
          "backend": {"type": "string", "enum": ["z3"]},
          "entry": {"type": "string", "minLength": 1},
          "objective": {
            "type": "string",
            "enum": ["sat_counterexample", "prove_unsat", "unsat_core"]
          },
          "severity": {"type": "string", "enum": ["critical", "high", "medium", "low"]}
        },
        "anyOf": [
          {"required": ["spec"]},
          {"required": ["source_spec"]}
        ]
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": true,
      "required": ["block_on"],
      "properties": {
        "block_on": {
          "type": "array",
          "items": {"type": "string", "enum": ["critical", "high", "medium", "low"]}
        },
        "output_dir": {
          "type": "string",
          "default": "output/formal"
        }
      }
    }
  }
}
